# Upstash Redis — required for production (Vercel deployment).
# Add this integration from the Vercel dashboard:
#   Project → Storage → Connect Store → Upstash Redis
# Vercel will inject these env vars automatically.
#
# For local development against a real KV store, copy this file to .env.local
# and paste the values from your Upstash dashboard (or the Vercel env vars page).
# Without these vars the app falls back to an in-memory store (dev only).
#
# Two naming schemes are accepted (the app reads either):
#   - Native Upstash:  UPSTASH_REDIS_REST_URL / UPSTASH_REDIS_REST_TOKEN
#   - Vercel KV / Upstash marketplace integration: KV_REST_API_URL / KV_REST_API_TOKEN
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# Optional: set an absolute base URL when not running on Vercel.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
